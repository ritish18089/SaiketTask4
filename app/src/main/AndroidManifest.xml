<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <queries>
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
    </queries>

    <application
        android:name=".IntentTransferApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Intent Transfer Demo"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.IntentTransferDemo">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.IntentTransferDemo.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".VideoTransferActivity" />
        <activity android:name=".VideoPreviewActivity" />
        <activity android:name=".ImageTransferActivity" />
        <activity android:name=".ImagePreviewActivity" />
        <activity android:name=".FileTransferActivity" />
        <activity android:name=".FilePreviewActivity" />
        <activity android:name=".SettingsActivity" />
        <activity android:name=".AboutActivity" />
        <activity android:name=".HelpCenterActivity" />
        <activity android:name=".PrivacyPolicyActivity" />
        <activity android:name=".TermsActivity" />

    </application>

</manifest>